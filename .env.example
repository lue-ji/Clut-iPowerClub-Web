# Google Apps Script Web App URL（部署 URL，結尾通常為 /exec）
# 正式環境請在 Vercel → Settings → Environment Variables 設定同名變數
VITE_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbyT_jKEuwunMfY3lguA15MIGQf2og4Ynj8fCX4nCK4EXcDGPRK0Qa_Nktt6xTDQAOhx3A/exec

# 報名／留言 API 驗證 token（與GAS後端一致）
VITE_JOIN_FORM_TOKEN=ipower20160802

# 選用：API 逾時與重試（GET 微笑牆適用；POST 報名不重試）
VITE_API_TIMEOUT=10000
VITE_API_RETRY_COUNT=3
VITE_API_RETRY_DELAY=1000
