# Google Apps Script 微笑牆 API
# 請替換為你的 GAS 執行 URL
VITE_GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_GAS_DEPLOYMENT_ID/exec

# 報名表單 Token
# 用於 JoinView 表單驗證
VITE_JOIN_FORM_TOKEN=your_secure_token_here

# API 配置（可選，已有預設值）
# 設置 API 請求超時時間（毫秒）
VITE_API_TIMEOUT=10000

# 設置 GET 請求最大重試次數
VITE_API_RETRY_COUNT=5

# 設置重試間隔（毫秒）
VITE_API_RETRY_DELAY=1000
